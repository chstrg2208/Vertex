datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Job {
  id           Int           @id @default(autoincrement())
  title        String
  company      String
  location     String
  salary       String
  tags         String[]
  description  String
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Candidate {
  id           Int           @id @default(autoincrement())
  name         String
  title        String
  email        String
  phone        String
  location     String
  summary      String
  skills       String[]
  status            String        @default("AVAILABLE") // "AVAILABLE", "VETTING", "PLACED", "ON_LEAVE"
  rating            Float         @default(5.0)
  internalNotes     String        @default("")
  englishLevel      String        @default("Intermediate")
  salaryExpectation String        @default("Negotiable")
  experience        Json          // Array of { company, role, duration, description }
  education         Json          // Array of { school, degree, duration }
  applications      Application[]
}

model Application {
  id              Int       @id @default(autoincrement())
  jobId           Int
  candidateId     Int
  status          String    // "APPLIED", "SCREENING", "INTERVIEW", "OFFERED", "HIRED", "REJECTED"
  billingRate     Float     @default(45000000.0)
  developerSalary Float     @default(35000000.0)
  createdAt       DateTime  @default(now())
  
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Post {
  id          Int       @id @default(autoincrement())
  authorName  String
  authorRole  String    // "recruiter", "candidate"
  content     String
  likesCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  comments    Comment[]
}

model Comment {
  id          Int      @id @default(autoincrement())
  postId      Int
  authorName  String
  content     String
  createdAt   DateTime @default(now())
  
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sender    String   // "recruiter", "candidate"
  recipient String   // "recruiter", "candidate"
  message   String
  createdAt DateTime @default(now())
}

model Partner {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  type      String   // "COMPANY", "FREELANCER"
  taxCode   String
  repName   String
  devsCount Int      @default(0)
  createdAt DateTime @default(now())
}

model Account {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   // "ta", "ba", "admin"
  createdAt DateTime @default(now())
}
